{
  "manifest_version": 3,
  "name": "Claude Usage Tracker",
  "version": "1.0.0",
  "description": "Track your Claude.ai usage quota and reset times in real-time",
  "author": "OpenCode User",
  
  "permissions": [
    "storage",
    "alarms",
    "cookies",
    "tabs"
  ],
  
  "host_permissions": [
    "*://claude.ai/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content.js"]
    }
  ],
  
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "icons/icon128.png",
    "default_title": "Claude Usage Tracker"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "512": "icons/icon512.png"
  }
}
